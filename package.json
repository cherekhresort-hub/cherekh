{
  "homepage": "https://cherekhcenter.com",
  "name": "cherekh-center",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "optimize:images": "node scripts/optimize-images.mjs",
    "build": "npm run optimize:images && tsc && vite build && node scripts/prerender-meta.mjs && node scripts/generate-sitemap.mjs",
    "seo:sitemap": "node scripts/generate-sitemap.mjs",
    "preview": "vite preview",
    "deploy:netlify": "npm run build && npx netlify-cli deploy --prod --dir=dist --functions=netlify/functions",
    "deploy:netlify:draft": "npm run build && npx netlify-cli deploy --dir=dist --functions=netlify/functions",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "postinstall": "update-browserslist-db"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/playfair-display": "^5.2.8",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@radix-ui/react-accordion": "^1.2.13",
    "@supabase/supabase-js": "^2.106.2",
    "clsx": "^2.1.1",
    "framer-motion": "^10.16.16",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.3",
    "react-slick": "^0.31.0",
    "recharts": "^3.8.1",
    "slick-carousel": "^1.8.1",
    "sweetalert2": "^11.26.25",
    "tailwind-merge": "^3.6.0",
    "usehooks-ts": "^3.1.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-slick": "^0.23.13",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.2.2",
    "update-browserslist-db": "^1.2.3",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.1.0"
  },
  "overrides": {
    "esbuild": "^0.25.0",
    "minimatch": "^9.0.7"
  }
}
